# Anthropic API（投稿文の生成に使用）
ANTHROPIC_API_KEY=

# Supabase（投稿の保存に使用。Project Settings > API から取得）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Discordへの通知用Webhook URL（チャンネル設定 > 連携サービス > ウェブフック）
DISCORD_WEBHOOK_URL=

# Vercel Cronからの呼び出しを認証するための任意の文字列（16文字以上のランダム文字列を推奨）
CRON_SECRET=

# ダッシュボードのログインパスワード
DASHBOARD_PASSWORD=
